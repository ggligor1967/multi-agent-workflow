# ============================================================================
# Multi-Agent AI Workflow - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run: pnpm test:llm to verify LLM connection
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Example: mysql://root:password@localhost:3306/workflow_db
DATABASE_URL=mysql://root:4212@localhost:3306/multi_agent_workflow

# ----------------------------------------------------------------------------
# LLM / AI API (Required for workflow execution)
# ----------------------------------------------------------------------------
# API key for the LLM provider (OpenAI-compatible endpoint)
# This is required for the agents to function
BUILT_IN_FORGE_API_KEY=sk-your-real-api-key-here

# LLM API endpoint URL (optional - has default)
# Leave empty to use default, or specify your OpenAI-compatible endpoint
# Examples:
#   https://api.openai.com/v1
#   https://api.anthropic.com/v1
#   https://your-custom-endpoint.com/v1
BUILT_IN_FORGE_API_URL=

# ----------------------------------------------------------------------------
# AUTHENTICATION (OAuth)
# ----------------------------------------------------------------------------
# Secret key for signing JWT tokens and cookies
# Generate a secure random string (e.g., openssl rand -base64 32)
JWT_SECRET=mysecretkey123randomstring

# Manus OAuth server URL for authentication
# Leave empty if not using Manus OAuth
OAUTH_SERVER_URL=

# OpenID of the user who should have admin privileges
# This user will be automatically assigned the "admin" role
OWNER_OPEN_ID=

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
# Application identifier (used for OAuth and tracking)
VITE_APP_ID=multi-agent-workflow

# Node environment (development | production | test)
# Automatically set by npm scripts, usually no need to set manually
NODE_ENV=development

# ----------------------------------------------------------------------------
# OPTIONAL / ADVANCED
# ----------------------------------------------------------------------------
# Port for the Express server (default: 5000 in dev, 3000 in prod)
# PORT=5000

# Enable debug logging (optional)
# DEBUG=true
